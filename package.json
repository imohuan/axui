{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:cdn": "vite build --config vite.config.cdn.ts",
    "dev:cdn": "concurrently -n build,serve -c cyan,green \"vite build --config vite.config.cdn.ts --watch\" \"live-server --port=3000 --entry-file=cdn-demo.html --no-browser\"",
    "preview": "vite preview",
    "prepush": "node scripts/install.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/vue": "^1.1.11",
    "@fontsource/geist": "^5.2.9",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@vueuse/core": "^14.3.0",
    "esbuild": "^0.28.0",
    "material-symbols": "^0.44.10",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.11",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "live-server": "^1.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  }
}
